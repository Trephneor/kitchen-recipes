# Hostnames come from .env (generated by setup.sh).
# Caddy obtains and renews Let's Encrypt certificates automatically.

{$AUTH_HOST} {
	reverse_proxy authelia:9091
}

{$RECIPES_HOST} {
	# Every request must carry a valid Authelia session (password + TOTP),
	# otherwise the user is redirected to the login portal.
	forward_auth authelia:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Email Remote-Name
	}
	reverse_proxy kitchen-recipes:80
}
